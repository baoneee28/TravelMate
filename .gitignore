# ============================================================
# TravelMate - .gitignore
# Project Spring Boot MVC + Thymeleaf
# Root TravelMate/ la project chinh duy nhat
# ============================================================

# === Maven build output ===
target/
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# === Archive folders (KHONG PHAI project chay chinh) ===
# Cac folder nay chi de tham chieu, khong code moi vao day
_archive_backend_legacy/
_archive_frontend_old/
_archive_frontend_legacy_backup/

# === Log files ===
*.log

# === STS (Spring Tool Suite) ===
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# === IntelliJ IDEA ===
.idea/
*.iws
*.iml
*.ipr

# === NetBeans ===
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# === VS Code ===
.vscode/

# === OS files ===
.DS_Store
Thumbs.db

# === Upload directory ===
src/main/resources/static/uploads/
